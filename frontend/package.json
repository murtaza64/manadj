{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "gen:keys": "uv run --project .. ../scripts/export/gen_key_table.py",
    "check:keys": "uv run --project .. ../scripts/export/gen_key_table.py --check",
    "predev": "npm run gen:keys",
    "dev": "vite",
    "prebuild": "npm run gen:keys",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pretest": "npm run gen:keys",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
  }
}
